+// Minimax approximations for EML (FMA-optimized)
+const float LOG2_E = 1.44269504089;
+const float LN_2   = 0.69314718056;
+
+float fast_exp(float x) {
+    float xc = clamp(x, -87.0, 87.0);
+    float w = xc * LOG2_E;
+    float i = floor(w);
+    float f = w - i;
+    float p = 1.00247605 + f * (0.65104678 + f * 0.34400111);
+    return p * ldexp(1.0, int(i));
+}
+
+float fast_ln(float x) {
+    if (x <= 0.0) return -1e38;
+    uint bx = floatBitsToUint(x);
+    float e = float(int((bx >> 23) & 0xFF) - 127);
+    float m = uintBitsToFloat((bx & 0x7FFFFF) | 0x3F800000);
+    float u = m - 1.0;
+    float poly = u * (0.98771793 + u * (-0.40916155 + u * 0.11513792));
+    return e * LN_2 + poly;
+}
